{
  "manifest_version": 3,
  "name": "YT Tile Scraper",
  "version": "0.1.0",
  "description": "Scrape YouTube video-tile metadata from the active tab and POST it to a local receiver (Python on 8765 or Java/Spring Boot on 8080).",
  "permissions": ["activeTab", "scripting", "storage", "alarms", "tabs"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*",
    "http://127.0.0.1:8080/*",
    "http://localhost:8080/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Scrape YouTube tiles",
    "default_popup": "popup.html"
  }
}
